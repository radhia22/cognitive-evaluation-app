rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation Blueprints
    function isValidDoctor(data) {
      return data.keys().hasAll(['name', 'email', 'createdAt']) &&
             data.keys().size() == 3 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.matches('^.+@.+$');
    }

    function isValidPatient(data) {
      return data.keys().hasAll(['doctorId', 'name', 'age', 'injuryType', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.doctorId is string &&
             data.name is string && data.name.size() > 0 &&
             data.age is number && data.age >= 0 &&
             data.injuryType is string;
    }

    // Rules
    match /doctors/{doctorId} {
      allow get: if isOwner(doctorId);
      allow create: if isOwner(doctorId) && isValidDoctor(request.resource.data);
      allow update: if isOwner(doctorId) && isValidDoctor(request.resource.data) &&
                      request.resource.data.email == resource.data.email;
    }

    match /patients/{patientId} {
      allow read: if isSignedIn() && resource.data.doctorId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.doctorId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.doctorId == request.auth.uid && isValidPatient(request.resource.data);
    }

    match /assignments/{assignmentId} {
      allow read, write: if isSignedIn() && resource.data.doctorId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.doctorId == request.auth.uid;
    }

    match /testResults/{resultId} {
      allow read, write: if isSignedIn() && resource.data.doctorId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.doctorId == request.auth.uid;
    }
  }
}
